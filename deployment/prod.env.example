# Production environment template
# Copy to prod.env and fill in real values. Keep this file out of version control.
VITE_API_BASE_URL=https://api.borderpassport.gov.rw/api
VITE_API_TIMEOUT=30000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_JWT_STORAGE_KEY=borderpassport_token
VITE_REFRESH_TOKEN_KEY=borderpassport_refresh
VITE_APP_NAME=Border Passport Management System
VITE_APP_VERSION=0.1.0
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true
