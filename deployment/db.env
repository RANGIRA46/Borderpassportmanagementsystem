# Database Configuration for Development

# PostgreSQL Connection Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=borderpassport
DB_USER=bpms_user
DB_PASSWORD=dev_password_change_me

# Database URL (for applications that support it)
DATABASE_URL=postgresql://bpms_user:dev_password_change_me@localhost:5432/borderpassport

# API Server Settings
API_PORT=3001

# Authentication Defaults (for local development only)
DEFAULT_ADMIN_EMAIL=admin@bpms.local
DEFAULT_ADMIN_PASSWORD=admin12345

DEFAULT_OFFICER_EMAIL=officer@bpms.local
DEFAULT_OFFICER_PASSWORD=officer12345

# Supabase Configuration (leave empty for local development)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Application Settings
VITE_API_BASE_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000
VITE_JWT_STORAGE_KEY=borderpassport_token
VITE_REFRESH_TOKEN_KEY=borderpassport_refresh
VITE_APP_NAME=Border Passport Management System (Dev)
VITE_APP_VERSION=0.1.0
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# Feature Flags
ENABLE_BIOMETRIC_CAPTURE=true
ENABLE_BORDER_INTEGRATION=true
ENABLE_ANALYTICS=false
ENABLE_EMAIL_NOTIFICATIONS=false

