# ============================================================
# Border Passport Management System - Environment Variables
# Copy this file to .env and fill in the required values.
# Never commit the .env file to version control.
# ============================================================

# ---- API Configuration ----
# Base URL for the backend REST API
VITE_API_BASE_URL=http://localhost:3000/api

# Request timeout in milliseconds
VITE_API_TIMEOUT=30000

# ---- Supabase Configuration ----
# Your Supabase project URL (found in Project Settings > API)
VITE_SUPABASE_URL=

# Your Supabase anonymous (public) API key
VITE_SUPABASE_ANON_KEY=

# ---- Authentication ----
# localStorage key used to persist the JWT access token
VITE_JWT_STORAGE_KEY=borderpassport_token

# localStorage key used to persist the refresh token
VITE_REFRESH_TOKEN_KEY=borderpassport_refresh

# ---- Application ----
VITE_APP_NAME=Border Passport Management System
VITE_APP_VERSION=0.1.0

# ---- Feature Flags ----
# Enable in-app and push notifications
VITE_ENABLE_NOTIFICATIONS=true

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=true
