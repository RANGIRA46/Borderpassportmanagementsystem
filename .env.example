# ============================================================
# Border Passport Management System — Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit .env.local or any file containing real secrets.
# ============================================================

# --- Frontend (Vite) ---
# All frontend variables MUST start with VITE_

# App Info
VITE_APP_NAME=Border Passport Management System
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Supabase (Frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Authentication (localStorage keys)
VITE_JWT_STORAGE_KEY=borderpassport_token
VITE_REFRESH_TOKEN_KEY=borderpassport_refresh

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true

# Error Tracking (optional)
VITE_SENTRY_DSN=

# --- Backend / Edge Functions ---
# These are configured in Supabase Dashboard (NOT exposed to frontend)

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000,https://your-production-domain.com

# --- Email / SMTP (optional) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="BPMS Notifications <noreply@example.com>"

# --- SMS via Twilio (optional) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# --- Docker / CI (optional) ---
REGISTRY=ghcr.io
IMAGE_NAME=rangira46/bpms-frontend
IMAGE_TAG=latest